page {
  height: 100vh;
  background: #f7f7f7;
}

.history-panel {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  min-height: 0;
  padding: 24rpx;
  box-sizing: border-box;
  color: #333;
}

.history-panel-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.history-panel-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.history-panel-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.history-panel-state {
  margin-top: 64rpx;
  text-align: center;
}

.history-panel-state-muted {
  color: #999;
  font-size: 28rpx;
}

.history-panel-hint {
  font-size: 28rpx;
  color: #999;
}

.history-panel-list {
  flex: 1;
  min-height: 0;
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.history-panel-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.history-panel-index {
  flex-shrink: 0;
  color: #999;
}

.history-panel-detail {
  flex: 1;
  min-width: 0;
}

.history-panel-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 24rpx;
  color: #999;
}

.history-panel-row + .history-panel-row {
  margin-top: 8rpx;
}

.history-panel-piece {
  color: #333;
}
