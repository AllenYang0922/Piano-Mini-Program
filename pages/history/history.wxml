<view class="history-panel">
  <view class="history-panel-body">
    <view class="history-panel-title">
      <text class="history-panel-title-text">当前已演奏曲目:</text>
    </view>

    <block wx:if="{{isLoading}}">
      <view class="history-panel-state">
        <text class="history-panel-hint">加载中...</text>
      </view>
    </block>
    <block wx:elif="{{performHistory.length > 0}}">
      <scroll-view class="history-panel-list" scroll-y type="list">
        <view
          wx:for="{{performHistory}}"
          wx:key="id"
          class="history-panel-item"
        >
          <view class="history-panel-index">{{index + 1}}.</view>
          <view class="history-panel-detail">
            <view class="history-panel-row">
              <text class="history-panel-piece">{{item.pieceName}}</text>
            </view>
            <view class="history-panel-row">
              <text>{{item.startedAtText}}</text>
              <text>{{item.successText}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </block>
    <block wx:else>
      <view class="history-panel-state history-panel-state-muted">
        <text>暂无演奏记录</text>
      </view>
    </block>
  </view>
</view>
