.songs-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7f7f7;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.song-list {
  padding: 24rpx;
}

.song-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
}

.song-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.song-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.song-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.song-actions .iconfont {
  font-size: 44rpx;
  color: #333;
  padding: 8rpx;
}

.song-artist {
  font-size: 26rpx;
  color: #999;
}

.loading-tip {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
